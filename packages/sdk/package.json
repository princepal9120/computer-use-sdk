{
  "name": "@opencoredev/computer-use-sdk",
  "version": "0.2.0",
  "description": "One TypeScript SDK for computer-use: Local, Browserbase, Browser Use, CUA, OpenAI, Anthropic, Steel, Hyperbrowser, Skyvern, OpenHands, Stagehand, AgentQL, Midscene, Nanobrowser, Playwright MCP, Firecrawl.",
  "homepage": "https://computer-use-sdk.vercel.app",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/princepal9120/computer-use-sdk.git",
    "directory": "packages/sdk"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./local": {
      "types": "./dist/providers/local/index.d.mts",
      "import": "./dist/providers/local/index.mjs"
    },
    "./browserbase": {
      "types": "./dist/providers/browserbase/index.d.mts",
      "import": "./dist/providers/browserbase/index.mjs"
    },
    "./browser-use": {
      "types": "./dist/providers/browser-use/index.d.mts",
      "import": "./dist/providers/browser-use/index.mjs"
    },
    "./cua": {
      "types": "./dist/providers/cua/index.d.mts",
      "import": "./dist/providers/cua/index.mjs"
    },
    "./firecrawl": {
      "types": "./dist/providers/firecrawl/index.d.mts",
      "import": "./dist/providers/firecrawl/index.mjs"
    },
    "./openai": {
      "types": "./dist/providers/openai/index.d.mts",
      "import": "./dist/providers/openai/index.mjs"
    },
    "./anthropic": {
      "types": "./dist/providers/anthropic/index.d.mts",
      "import": "./dist/providers/anthropic/index.mjs"
    },
    "./steel": {
      "types": "./dist/providers/steel/index.d.mts",
      "import": "./dist/providers/steel/index.mjs"
    },
    "./hyperbrowser": {
      "types": "./dist/providers/hyperbrowser/index.d.mts",
      "import": "./dist/providers/hyperbrowser/index.mjs"
    },
    "./skyvern": {
      "types": "./dist/providers/skyvern/index.d.mts",
      "import": "./dist/providers/skyvern/index.mjs"
    },
    "./openhands": {
      "types": "./dist/providers/openhands/index.d.mts",
      "import": "./dist/providers/openhands/index.mjs"
    },
    "./stagehand": {
      "types": "./dist/providers/stagehand/index.d.mts",
      "import": "./dist/providers/stagehand/index.mjs"
    },
    "./agentql": {
      "types": "./dist/providers/agentql/index.d.mts",
      "import": "./dist/providers/agentql/index.mjs"
    },
    "./midscene": {
      "types": "./dist/providers/midscene/index.d.mts",
      "import": "./dist/providers/midscene/index.mjs"
    },
    "./nanobrowser": {
      "types": "./dist/providers/nanobrowser/index.d.mts",
      "import": "./dist/providers/nanobrowser/index.mjs"
    },
    "./playwright-mcp": {
      "types": "./dist/providers/playwright-mcp/index.d.mts",
      "import": "./dist/providers/playwright-mcp/index.mjs"
    },
    "./metadata": {
      "types": "./dist/metadata.d.mts",
      "import": "./dist/metadata.mjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.mts",
      "import": "./dist/testing/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "bun run build",
    "dev": "tsdown --watch src",
    "lint": "oxlint src tests",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests --timeout=15000"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.112.1",
    "@browserbasehq/sdk": "^2.16.0",
    "@browserbasehq/stagehand": "^3.7.0",
    "@hyperbrowser/sdk": "^0.91.3",
    "@mendable/firecrawl-js": "^4.30.1",
    "@midscene/web": "^1.10.5",
    "@trycua/computer": "^0.1.6",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.13.14",
    "agentql": "^1.18.1",
    "browser-use-sdk": "^3.9.0",
    "openai": "^6.48.0",
    "steel-sdk": "^0.18.0",
    "tsdown": "^0.16.6",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@browserbasehq/sdk": "^2.0.0",
    "@browserbasehq/stagehand": ">=2.0.0",
    "@hyperbrowser/sdk": ">=0.50.0",
    "@mendable/firecrawl-js": "^4.0.0",
    "@midscene/web": ">=0.10.0",
    "@trycua/computer": "^0.1.0",
    "agentql": ">=1.0.0",
    "browser-use-sdk": "^3.0.0",
    "openai": ">=4.0.0",
    "steel-sdk": ">=0.10.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "@browserbasehq/sdk": { "optional": true },
    "@browserbasehq/stagehand": { "optional": true },
    "@hyperbrowser/sdk": { "optional": true },
    "@mendable/firecrawl-js": { "optional": true },
    "@midscene/web": { "optional": true },
    "@trycua/computer": { "optional": true },
    "agentql": { "optional": true },
    "browser-use-sdk": { "optional": true },
    "openai": { "optional": true },
    "steel-sdk": { "optional": true }
  },
  "engines": {
    "node": ">=22 <26"
  }
}
