{
  "name": "computer-use-sdk",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check-types": "bun run typecheck",
    "test": "turbo run test",
    "format": "oxfmt --write .",
    "check": "bun run format && bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22 <26"
  },
  "packageManager": "bun@1.3.14"
}
